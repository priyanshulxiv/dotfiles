#!/bin/sh

# Script modified from: https://github.com/LukeSmithxyz/voidrice/blob/master/.local/bin/dmenurecord

# Requires
# sudo pacman -S ffmpeg
# sudo pacman -S slop

# Usage:
# `$0`: Ask for recording type via rofi
# `$0 screencast`: Record both audio and screen
# `$0 video`: Record only screen
# `$0 audio`: Record only audio
# `$0 kill`: Kill existing recording
#
# If there is already a running instance, user will be prompted to end it.

getdim() { xrandr | grep -oP '(?<=current ).*(?=,)' | tr -d ' ' ;}

killrecording() { \
	recpid="$(cat /tmp/recordingpid)"
	kill -15 "$recpid"

	rm -f /tmp/recordingpid && pkill -RTMIN+3 i3blocks
}

screencast() {
	mkdir -p "$HOME/Videos/screencast"
	ffmpeg -y \
	-f x11grab \
	-framerate 30 \
	-s "$(getdim)" \
	-i "$DISPLAY" \
	-r 24 \
	-f alsa -thread_queue_size 1024 -i default \
	-c:v h264 \
	-crf 23 -preset ultrafast -c:a aac \
	-af "afftdn=nf=-75" \
	"$HOME/Videos/screencast/screencast-$(date +%F-%H-%M-%S).mp4" &

	echo $! > /tmp/recordingpid && pkill -RTMIN+3 i3blocks
}

audio() {
	mkdir -p "$HOME/Music/audiorec"
	ffmpeg \
	-f alsa -i default \
	-af "afftdn=nf=-75" \
	-c:a aac -b:a 128k \
	"$HOME/Music/audiorec/audio-$(date +%F-%H-%M-%S).mkv" &

	echo $! > /tmp/recordingpid && pkill -RTMIN+3 i3blocks
}

video() {
	mkdir -p "$HOME/Videos/videorec"
	ffmpeg \
	-f x11grab \
	-framerate 30 \
	-s "$(getdim)" \
	-i "$DISPLAY" \
	-c:v libx264 -crf 23 -r 30 \
	"$HOME/Videos/videorec/video-$(date +%F-%H-%M-%S).mkv" &

	echo $! > /tmp/recordingpid && pkill -RTMIN+3 i3blocks
}

videoselected() {
	slop -f "%x %y %w %h" > /tmp/slop
	read -r X Y W H < /tmp/slop
	rm /tmp/slop

	mkdir -p "$HOME/Videos/videorec"
	ffmpeg \
		-f x11grab \
		-framerate 30 \
		-video_size "$W"x"$H" \
		-i :0.0+"$X,$Y" \
		-c:v libx264 -crf 23 -r 30 \
		"$HOME/Videos/videorec/box-$(date +%F-%H-%M-%S).mkv" &

	echo $! > /tmp/recordingpid && pkill -RTMIN+3 i3blocks
}

webcam() {
	mkdir -p "$HOME/Videos/webcam"
	ffmpeg \
	-f v4l2 \
	-use_wallclock_as_timestamps 1 \
	-i /dev/video0 \
	-video_size 640x480 \
	"$HOME/Videos/webcam/webcam-$(date +%F-%H-%M-%S).mkv" &

	echo $! > /tmp/recordingpid && pkill -RTMIN+3 i3blocks
}

webcamhidef() {
	mkdir -p "$HOME/Videos/webcam"
	ffmpeg \
	-f v4l2 \
	-use_wallclock_as_timestamps 1 \
	-i /dev/video0 \
	-video_size 1920x1080 \
	"$HOME/Videos/webcam/webcam-$(date +%F-%H-%M-%S).mkv" &

	echo $! > /tmp/recordingpid && pkill -RTMIN+3 i3blocks
}

askrecording() { \
	choice=$(printf "screencast\\nvideo\\nvideo selected\\naudio\\nwebcam\\nwebcam (hi-def)" | rofi -dmenu -l 6 -i -p "Select recording style")
	case "$choice" in
		screencast) screencast;;
		audio) audio;;
		video) video;;
		*selected) videoselected;;
		webcam) webcam;;
		"webcam (hi-def)") webcamhidef;;
	esac
}

asktoend() { \
	response=$(printf "No\\nYes" | rofi -l 2 -dmenu -i -p "Recording still active. End recording?") &&
	[ "$response" = "Yes" ] && killrecording
}

case "$1" in
	screencast) killrecording && screencast;;
	audio) killrecording && audio;;
	video) killrecording && video;;
	*selected) killrecording && videoselected;;
	kill) killrecording;;
	*) if [ -f /tmp/recordingpid ]; then
		asktoend && exit
	else
		askrecording
		fi ;;
esac
