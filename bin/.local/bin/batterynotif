#!/bin/bash

# Requires
# sudo pacman -S dunst

# Make sure that there aren't multiple instances of the script running
cd $(dirname $0)
PIDFILE=/tmp/$(basename $0 .sh).pid

if [ -f $PIDFILE ]; then
	if [ -e /proc/$(cat $PIDFILE) ]; then
		exit 0
	fi
fi
echo $BASHPID > $PIDFILE

# Detect battery (BAT0, BAT1, etc...)
BATPATH=$(dirname /sys/class/power_supply/BAT*/capacity | head -n 1)
if [ ! -d "$BATPATH" ]; then
	notify-send -u critical "󰂑 Battery Error!" "No battery found on this system."
	exit 1
fi

# Battery Notification script starts here
CRITICAL_ALERT=15
NORMAL_ALERT=25
LOW_ALERT=40

# Track current state
last_alert=""
full_notified=false

while true; do
	batteryCapacity=$(cat "$BATPATH/capacity")
	batteryStatus=$(cat "$BATPATH/status")

	if [[ "$batteryStatus" == "Discharging" ]]; then
		full_notified=false

		if [[ $batteryCapacity -le $CRITICAL_ALERT ]]; then
			if [[ "$last_alert" != "critical" ]]; then
				notify-send -u critical "󰂎 Battery Low" "Battery is at ${batteryCapacity}%"
				last_alert="critical"
			fi
		elif [[ $batteryCapacity -le $NORMAL_ALERT ]]; then
			if [[ "$last_alert" != "normal" ]]; then
				notify-send -u normal "󰁻 Battery Warning" "Battery is at ${batteryCapacity}%"
				last_alert="normal"
			fi
		elif [[ $batteryCapacity -le $LOW_ALERT ]]; then
			if [[ "$last_alert" != "low" ]]; then
				notify-send -u low "󰁽 Battery Info" "Consider plugging in. Battery is at ${batteryCapacity}%"
				last_alert="low"
			fi
		else
			last_alert=""
		fi

	elif [[ "$batteryStatus" == "Charging" ]]; then
		last_alert=""

		if [[ $batteryCapacity -ge 80 ]]; then
			if ! $full_notified; then
				notify-send -u normal "󰁹 Battery has reached the 80% mark." "You can now unplug the charger."
				full_notified=true
			fi
		fi

	elif [[ "$batteryStatus" == "Not Charging" ]]; then
		if ! $full_notified; then
			notify-send -u low "󰁹 Device Fully Charged" "You can now unplug the charger."
			full_notified=true
		fi
	fi

	# Check status consistently every 60 seconds
	sleep 60
done
